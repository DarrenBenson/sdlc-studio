#!/usr/bin/env bash
# SDLC Studio pre-commit gate.
#
# Runs the repo's npm-independent guards so style, neutrality, line-budget,
# version, link, and index-drift breakage cannot reach a commit. Every failure
# is explained in detail: what the guard enforces, the full violation output,
# and how to fix it (self-diagnosing findings, per CR0132).
#
# Enable once per clone:  bash tools/enable-hooks.sh   (sets core.hooksPath)
# Bypass (emergencies only):  git commit --no-verify
set -uo pipefail

repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || { echo "pre-commit: not a git repo"; exit 1; }
cd "$repo_root" || exit 1
skill=".claude/skills/sdlc-studio/scripts"
fail=0

# Colour only when writing to a terminal.
if [ -t 1 ]; then R=$'\033[31m'; G=$'\033[32m'; Y=$'\033[33m'; B=$'\033[1m'; N=$'\033[0m'; else R=; G=; Y=; B=; N=; fi

# run KEY  "what it enforces"  "how to fix"  -- command...
run() {
  local key="$1" what="$2" fixhint="$3"; shift 3
  [ "$1" = "--" ] && shift
  local out
  # Stashed for the caller on BOTH paths. A green run's output used to be discarded, but the
  # budget lane needs to know how many tests actually ran, and that is only knowable from the
  # output of a run that passed as well as one that failed (BG0239).
  if out="$("$@" 2>&1)"; then
    last_run_out="$out"
    printf '  %sok%s   %s\n' "$G" "$N" "$key"
    return 0
  fi
  last_run_out="$out"
  fail=1
  printf '  %sFAIL%s %s%s%s\n' "$R" "$N" "$B" "$key" "$N"
  printf '       enforces: %s\n' "$what"
  if [ -n "$out" ]; then
    printf '       %s─ details ─%s\n' "$Y" "$N"
    printf '%s\n' "$out" | sed 's/^/         /'
  fi
  printf '       %s→ fix:%s %s\n\n' "$B" "$N" "$fixhint"
}

echo "${B}sdlc-studio pre-commit gate${N}"

# Concurrent-write window guard. A window is a record on disk saying another process may
# be REWRITING named paths in this working tree right now: an independent review applying
# and restoring mutants, a mutation run, a reviewer pulling an old revision back over a
# file. While one is open, what is staged for a claimed path is not necessarily what the
# author wrote, and a green gate is no evidence otherwise - the write that prompted this
# guard was a `git show <sha>:...retro.py > retro.py` redirect following a symlink into
# the live tree, and it was caught only because the reverted source happened to fail the
# suite. A rewrite leaving the suite green would have committed in silence under a commit
# message about paperwork. So this REFUSES rather than warning: a warning inside a passing
# run is exactly what the observed failure mode defeats.
#
# Record contract (written by the window's owner, read here):
#   sdlc-studio/.local/*window*.json  or  sdlc-studio/.local/windows/*.json
#   {"owner": "who holds it", "opened": "<iso8601>", "paths": ["a/file.py", "dir/", "glob*"]}
# No record on disk means no window: this guard then prints nothing and costs nothing.
# A record that is unreadable, is not an object, or names no paths is read as an OPEN
# window claiming the whole tree - a truncated record must never read as "closed".
window_out="$(python3 - <<'PY'
import fnmatch
import json
import subprocess
import sys
from pathlib import Path

LOCAL = Path("sdlc-studio") / ".local"
EVERYTHING = "*"


def records():
    """Every window record on disk, in both spellings of the contract."""
    found = []
    if LOCAL.is_dir():
        found += sorted(p for p in LOCAL.glob("*window*.json") if p.is_file())
        sub = LOCAL / "windows"
        if sub.is_dir():
            found += sorted(p for p in sub.glob("*.json") if p.is_file())
    return found


def parse(path):
    """(owner, opened, claimed paths, clear hint). Anything unreadable claims the tree."""
    try:
        data = json.loads(path.read_text(encoding="utf-8"))
    except Exception:
        return "unknown (the record is unreadable)", "", [EVERYTHING], ""
    if not isinstance(data, dict):
        return "unknown (the record is unreadable: not a JSON object)", "", [EVERYTHING], ""
    owner = str(data.get("owner") or "").strip() or "unknown"
    opened = str(data.get("opened_at") or data.get("opened")
                 or data.get("started") or "").strip()
    raw = data.get("paths")
    if isinstance(raw, str):
        raw = [raw]
    # A record may name the command that clears it; that beats any guess made here.
    clear = str(data.get("clear_with") or "").strip()
    if not isinstance(raw, list):
        return owner, opened, [EVERYTHING], clear
    claimed = []
    for x in raw:
        # A claim that is not a string is a claim this reader cannot interpret. It used to be
        # str()-ed - so [{"path": "tools/thing.py"}] became "{'path': 'tools/thing.py'}", which
        # matched nothing, and the commit rewriting that very file LANDED. Objects, nested
        # lists and numbers all failed OPEN that way. An uninterpretable claim now claims the
        # whole tree: the record says a writer is active, and the one direction this may never
        # be wrong in is "harmless".
        if not isinstance(x, str):
            return owner, opened, [EVERYTHING], clear
        if x.strip():
            claimed.append(x.strip())
    # A window that does not say what it may rewrite has not said it may rewrite nothing.
    return owner, opened, (claimed or [EVERYTHING]), clear


def claims(pattern, staged):
    """True when `pattern` covers the staged path: the path itself, a directory it sits
    under, or a glob it matches. Two clauses, not four: fnmatch already answers the exact
    case (a wildcard-free pattern matches only itself), the whole-tree case (EVERYTHING is
    just `*`), and - since its `*` crosses `/` - a `pat + "/*"` spelling too. Each of those
    three was written here first and deleted after a mutant removing it survived.

    Uninterpretable claims fail SAFE. `git diff --cached --name-only` is always repo-relative,
    so an ABSOLUTE claim can never equal a staged path: `window open --paths <abs>/tools/x.py`
    announced a rewrite and then matched nothing, and the commit rewriting that file landed.
    A TRAVERSING claim is the same failure by a relative spelling - `tools/../tools/x.py` names
    exactly `tools/x.py` and matches nothing as a literal pattern, and that commit landed too.
    Windows are normalised to repo-relative at open time; a record already on disk carrying
    either spelling is read here as claiming everything."""
    if not isinstance(pattern, str):
        return True
    pat = pattern.strip()
    if pat.startswith("./"):
        pat = pat[2:]
    pat = pat.rstrip("/")
    if pat in ("", "."):
        return True   # a claim on the repo root ("/", ".") is a claim on everything
    if pat.startswith("/"):
        return True   # absolute: not comparable with a repo-relative staged path
    if pat == ".." or pat.startswith("../") or "/../" in pat or pat.endswith("/.."):
        return True   # traversal: names a real file, matches nothing as a literal pattern
    if staged.startswith(pat + "/"):   # a directory claim covers everything beneath it
        return True
    return fnmatch.fnmatch(staged, pat)


def staged_paths():
    """Repo-relative staged paths, or None when git could not be asked."""
    try:
        out = subprocess.run(
            ["git", "-c", "core.quotepath=false", "diff", "--cached", "--name-only"],
            capture_output=True, text=True)
    except OSError:
        return None
    if out.returncode != 0:
        return None
    return [ln.strip() for ln in out.stdout.splitlines() if ln.strip()]


def main():
    open_windows = records()
    if not open_windows:
        return 0
    staged = staged_paths()
    refused = False
    for rec in open_windows:
        owner, opened, claimed, clear = parse(rec)
        rel = rec.as_posix()
        when = " (opened %s)" % opened if opened else ""
        if staged is None:
            hit = ["(the staged file list could not be read, so every path is treated "
                   "as claimed)"]
        else:
            hit = [s for s in staged if any(claims(c, s) for c in claimed)]
        if not hit:
            print("  note concurrent-write window OPEN: %s, owner %s%s. No staged path "
                  "is claimed by it, so this commit proceeds." % (rel, owner, when))
            continue
        refused = True
        print("  REFUSED  a concurrent-write window claims a staged path")
        print("       record:  %s" % rel)
        print("       owner:   %s%s" % (owner, when))
        print("       claims:  %s" % ", ".join(claimed))
        print("       staged path(s) this window claims:")
        for s in hit:
            print("         - %s" % s)
        print("       While the window is open, what is staged for a claimed path is not")
        print("       necessarily what you wrote: another process may be rewriting it. A")
        print("       green gate is no evidence otherwise - a rewrite that leaves the tests")
        print("       passing commits in silence.")
        print("       -> fix: stage only the paths the window does not claim, by naming")
        print("          them - `git add <path> ...` then `git commit` - never `git add -A`.")
        print("          Otherwise wait for the window's owner to close it.")
        print("       -> stale window? A killed process leaves its record behind and nothing")
        print("          clears it. Check with the owner, then clear it:")
        if clear:
            print("          %s" % clear)
        print("          rm %s" % rel)
    return 1 if refused else 0


try:
    sys.exit(main())
except Exception as exc:  # never block a commit on this guard's own confusion
    print("  note window guard could not run (%s); it did not check this commit." % exc)
    sys.exit(0)
PY
)"
window_rc=$?
if [ "$window_rc" -eq 1 ]; then
  printf '%s\n' "$window_out"
  printf '\n%sCommit blocked.%s A concurrent-write window claims a path this commit stages.\n' "$R" "$N"
  printf 'Genuine emergency only: %sgit commit --no-verify%s\n' "$B" "$N"
  exit 1
elif [ "$window_rc" -ne 0 ]; then
  # Said out loud rather than skipped in silence: an interpreter that is missing or that
  # died leaves this commit unchecked, and that must not look like a clean check.
  printf '  %snote%s window guard exited %s - it did NOT check this commit for an open window.\n' \
    "$Y" "$N" "$window_rc"
  [ -n "$window_out" ] && printf '%s\n' "$window_out"
fi
[ "$window_rc" -eq 0 ] && [ -n "$window_out" ] && printf '%s\n' "$window_out"

run "style" \
  "house style: no em-dash (U+2014); no jargon (synergy/leverage/robust/journey); no internal provenance tags (CR1234) in reference/help/scripts" \
  "reword the flagged line; a legitimate case can be allowlisted in tools/style-allowlist.txt" \
  -- bash tools/lint-style.sh

run "links" \
  "every markdown anchor link (#heading) resolves to a real heading" \
  "correct the #anchor, or add/rename the target heading it points at" \
  -- python3 tools/check_links.py

run "skill-spec" \
  "SKILL.md frontmatter conforms to the Agent Skills spec subset" \
  "align the frontmatter fields flagged above with the spec" \
  -- python3 tools/validate_skill.py

run "versions" \
  "the version string is consistent across the authoritative files" \
  "sync the version in each file named above (or bump them together)" \
  -- python3 tools/check_versions.py

run "budgets" \
  "each reference-*.md stays under its declared line ceiling (keeps load cost bounded)" \
  "shrink the file, or raise its ceiling in tools/check_budgets.py deliberately (with a rationale comment)" \
  -- python3 tools/check_budgets.py

run "neutrality" \
  "no private consuming-project name leaks into a tracked file (the skill repo is domain-neutral)" \
  "generalise the name (e.g. to 'a consuming project'); the checker redacts the term, so grep your diff for it" \
  -- python3 tools/check_neutrality.py

run "action-pins" \
  "every GitHub Action is pinned to a full commit SHA (a moved tag cannot inject code into CI)" \
  "pin the flagged Action to its tag's commit SHA: uses: owner/repo@<40-hex> # vN" \
  -- bash tools/check_action_pins.sh

# The engagement floor over the PENDING commit. The standing floor lane inside the gate
# below reads committed history, so it could never see a violation the commit it is gating
# was about to create: the condition does not exist until the commit lands. Observed - the
# floor reported 0 violations, the gate passed, the commit landed, and the same check run
# seconds later reported 2 NEW violations in files nothing had touched.
run "floor-pending" \
  "the engagement floor over the STAGED index: a unit THIS commit puts below the floor (multi-file, no acceptance criterion, no declared footprint) is refused now rather than discovered one commit later. It reads the index, NOT the commit message - git writes the message after this hook runs - so a unit named only in the message is still judged next commit" \
  "plan the unit (one acceptance criterion, a Verify line, or a linked plan), or declare a real single-file footprint in its Affects field; the lane prints the per-unit remedies" \
  -- python3 "$skill/engagement_floor.py" check --pending --root .

# Comprehensive artefact gate (fast, ~1s): conformance, reconcile drift, validate,
# integrity, duplicate-id, doc-coverage, doc-freshness. This is the same gate CI runs.
if gate_out="$(python3 "$skill/gate.py" --root . 2>&1)"; then
  printf '  %sok%s   gate (conformance / reconcile / validate / integrity / duplicate-id / docs)\n' "$G" "$N"
else
  fail=1
  printf '  %sFAIL%s %sgate%s (conformance / reconcile / validate / integrity / duplicate-id / docs)\n' "$R" "$N" "$B" "$N"
  printf '       %s─ checks ─%s\n' "$Y" "$N"
  printf '%s\n' "$gate_out" | grep -E '\[(FAIL|warn)\]|^gate:' | sed 's/^/         /'
  # Reconcile drift is the common case: list each item with its own fix (self-diagnosing).
  DRIFT_JSON="$(python3 "$skill/reconcile.py" detect --format json 2>/dev/null)"
  drift_report="$(DRIFT_JSON="$DRIFT_JSON" python3 -c '
import os, json
try:
    d = json.loads(os.environ.get("DRIFT_JSON", ""))
except Exception:
    d = {}
for t, info in d.get("types", {}).items():
    for x in info.get("drift", []):
        print("%s %s: %s -> %s" % (t, x.get("id") or "(summary)", x.get("kind"), x.get("fix", "no fix hint")))
')"
  if [ -n "$drift_report" ]; then
    printf '       %s─ drift detail ─%s\n' "$Y" "$N"
    printf '%s\n' "$drift_report" | sed 's/^/         /'
  fi
  printf '       %s→ fix:%s address each failing check; run the named script for per-item detail (e.g. `%s/validate.py check`, `%s/conformance.py`); mechanical drift clears with `%s/reconcile.py apply`\n\n' "$B" "$N" "$skill" "$skill" "$skill"
fi

# Markdown mechanics (markdownlint-cli, a devDependency). Prefer the npm-local
# binary so `npm install` is enough - no global install needed. If Node is absent
# entirely, say so loudly: it is the one guard CI enforces that cannot run here.
md_cmd=""
if [ -x node_modules/.bin/markdownlint ]; then
  md_cmd="node_modules/.bin/markdownlint"
elif command -v markdownlint >/dev/null 2>&1; then
  md_cmd="markdownlint"
fi
if [ -n "$md_cmd" ]; then
  run "markdown" \
    "markdown mechanics: blank lines around lists (MD032), heading levels, fenced blocks" \
    "auto-fix most with: npm run lint:fix" \
    -- $md_cmd '**/*.md' --ignore node_modules
  # The shipped payload lives under a dot-directory the glob above cannot see; lint it
  # explicitly with its own config (template/example rules relaxed, mechanics enforced).
  # `.claude/worktrees/` holds transient agent worktrees (parallel-delivery scratch), which
  # are never shipped payload and carry in-progress files - excluded so a builder's
  # half-written markdown cannot block an unrelated commit in the main tree.
  run "markdown-payload" \
    "markdown mechanics of the SHIPPED skill payload (.claude/, invisible to the '**/*.md' glob)" \
    "auto-fix most with: npm run lint:fix" \
    -- $md_cmd --config .claude/skills/sdlc-studio/.markdownlint.json '.claude/**/*.md' \
       --ignore '.claude/worktrees/**'
else
  printf '  %sSKIP%s markdown - markdownlint not found. Run %snpm install%s to enable it locally.\n' "$Y" "$N" "$B" "$N"
  printf '       CI still enforces it, so a markdown-mechanics error can pass here and fail on push.\n'
fi

# Unit tests: only when the commit touches a file that can change a test outcome -
# scripts/, tools/, or templates/ (several skill tests assert over the shipped templates,
# so a template edit can break the suite). A pure README/CHANGELOG/reference/help commit
# cannot, and paying ~2.5 minutes for it is how a guard gets bypassed.
#
# The suites no longer RUN here. Git invokes pre-commit before the commit message exists -
# at this point $GIT_DIR/COMMIT_EDITMSG is absent, or still holds the PREVIOUS commit's
# message, which is why the floor-pending lane above cannot read it either. So no ordering
# of lanes inside this hook could ever put the commit-message rules ahead of a 2.5-minute
# run, and a one-line subject defect was refused only after the whole gate had been paid
# for, then paid for again on the retry. The lanes therefore live in the commit-msg hook,
# behind the message check; this hook decides only whether they are SELECTED.
#
# The handover is a one-shot record in the git directory - per worktree, and never in the
# working tree, because a gate that dirties the tree it is gating trains people to stage
# past it. It is written or removed on EVERY path through this block, and commit-msg
# removes it before running: a record that outlived its commit would charge the next
# commit-msg-only operation (git merge runs commit-msg without pre-commit) for a suite run
# nobody asked for.
#
# The skip is NAMED, never silent: a guard that quietly does not run is indistinguishable
# from one that ran and passed, and that is precisely the state in which a real regression
# ships. Two suites: shipped skill scripts, and the repo-only tools/ checkers.
handoff="$(git rev-parse --git-path sdlc-gate-suites 2>/dev/null || true)"
[ -n "$handoff" ] || handoff="$(git rev-parse --git-dir 2>/dev/null)/sdlc-gate-suites"
rm -f "$handoff" 2>/dev/null
test_relevant='^\.claude/skills/sdlc-studio/scripts/|^\.claude/skills/sdlc-studio/templates/|^tools/'
if [ "$fail" -eq 0 ] && git diff --cached --name-only | grep -qE "$test_relevant"; then
  # This hook's share of the gate travels with the record, so the per-commit total the
  # budget reads still covers BOTH hooks rather than only the half that runs last.
  if printf 'precommit_seconds=%s\n' "$SECONDS" > "$handoff" 2>/dev/null; then
    printf '  %snote%s unit suites selected - they run in the commit-msg hook, after the commit\n' "$Y" "$N"
    printf '       message rules, so a message defect is refused in seconds instead of after them.\n'
  else
    # A handover that cannot be written means the suites will not run at all. Refused, not
    # warned: an unrunnable expensive lane inside an otherwise green gate is the silent
    # coverage loss every named skip in this hook exists to prevent.
    fail=1
    printf '  %sFAIL%s %ssuite-handover%s\n' "$R" "$N" "$B" "$N"
    printf '       enforces: the unit suites run in the commit-msg hook, and this hook hands the\n'
    printf '                 selection over in %s\n' "$handoff"
    printf '       %s-> fix:%s make the git directory writable, then commit again.\n\n' "$B" "$N"
  fi
elif [ "$fail" -ne 0 ]; then
  printf '  %sSKIP%s unit suites - a cheaper lane already failed, so the commit is blocked either way.\n' "$Y" "$N"
  printf '       Fix the failure above and commit again; the suites run once the cheap guards are green.\n'
else
  printf '  %sSKIP%s unit suites - no test-relevant file staged (scripts/, templates/, tools/).\n' "$Y" "$N"
  printf '       Docs-only commit: style, links, budgets, markdown and the artefact gate still ran.\n'
fi

if [ "$fail" -ne 0 ]; then
  printf '\n%sCommit blocked.%s Fix the failures above (each lists how), then commit again.\n' "$R" "$N"
  printf 'Genuine emergency only: %sgit commit --no-verify%s\n' "$B" "$N"
  # A blocked commit never reaches commit-msg, so the handover must not survive it.
  rm -f "$handoff" 2>/dev/null
  exit 1
fi
# Honest about what is still owed: "green" over a gate whose expensive half has not run yet
# would read as a finished verdict.
if [ -e "$handoff" ]; then
  printf '%scheap lanes green.%s Commit-message rules next, then the unit suites.\n' "$G" "$N"
else
  printf '%sgate green.%s\n' "$G" "$N"
fi
exit 0
